# Nivel de log da CLI: TRACE, DEBUG, INFO, WARNING, ERROR
JARVIS_LOG_LEVEL=INFO

# Modelos locais do Ollama
JARVIS_OLLAMA_BASE_URL=http://localhost:11434/v1
JARVIS_OLLAMA_MODEL=qwen3.5:4b
JARVIS_OLLAMA_FALLBACK_MODEL=qwen3.5:2b
JARVIS_OLLAMA_TEMPERATURE=0.1
JARVIS_OLLAMA_MAX_TOKENS=96
JARVIS_OLLAMA_KEEP_ALIVE=30m

# Whisper MLX local no Apple Silicon
JARVIS_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo-q4
JARVIS_WHISPER_TEMPERATURE=0.0
JARVIS_WHISPER_NO_SPEECH_PROB=0.6
JARVIS_WHISPER_TTFS_P99_LATENCY=1.0

# Voz local Kokoro
JARVIS_KOKORO_VOICE=pm_alex
# JARVIS_KOKORO_MODEL_PATH=/caminho/opcional/kokoro-v1.0.onnx
# JARVIS_KOKORO_VOICES_PATH=/caminho/opcional/voices-v1.0.bin

# Opcional: force devices especificos. Descubra com `uv run jarvis devices`.
# JARVIS_INPUT_DEVICE_INDEX=0
# JARVIS_OUTPUT_DEVICE_INDEX=1

# Normalmente nao precisa mudar.
JARVIS_AUDIO_IN_SAMPLE_RATE=16000
JARVIS_AUDIO_OUT_SAMPLE_RATE=24000
JARVIS_VAD_START_SECS=0.2
JARVIS_VAD_STOP_SECS=0.2

# Evita o assistente responder no meio de falas ainda incompletas.
JARVIS_FILTER_INCOMPLETE_USER_TURNS=true
JARVIS_INCOMPLETE_SHORT_TIMEOUT=6.0
JARVIS_INCOMPLETE_LONG_TIMEOUT=12.0

# Warmup carrega Whisper e Ollama antes de entrar em modo escuta.
JARVIS_PREWARM_ENABLED=true
JARVIS_OLLAMA_PREWARM_ENABLED=false

# Em modo local com alto-falante + microfone, ajuda a evitar que o assistente se ouca.
# Tradeoff: interromper a fala do assistente sem fones deixa de funcionar.
JARVIS_ECHO_SUPPRESSION_ENABLED=true
JARVIS_ECHO_SUPPRESSION_RELEASE_MS=350

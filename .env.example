JARVIS_METAL_MEMORY_LIMIT_GB=9.5
JARVIS_METAL_WIRED_LIMIT_GB=8.5
JARVIS_METAL_CACHE_LIMIT_GB=0.5
JARVIS_LLM_MAX_KV_SIZE=4096

JARVIS_STT_BACKEND=speech_analyzer
JARVIS_STT_LOCALE=pt-BR
JARVIS_STT_BRIDGE_BIN=./bridges/apple/SpeechAnalyzerCLI/.build/release/speechanalyzer-cli

JARVIS_LLM_HOT_PATH=foundation_models
JARVIS_LLM_HOT_PATH_URL=http://127.0.0.1:8008
JARVIS_LLM_HOT_PATH_BRIDGE_BIN=./bridges/apple/FoundationModelsBridge/.build/release/foundation-models-bridge
JARVIS_LLM_DELIBERATIVE=mlx_lm
JARVIS_LLM_DELIBERATIVE_MODEL=mlx-community/Qwen3-8B-4bit
JARVIS_LLM_DELIBERATIVE_TEMPERATURE=0.2
JARVIS_LLM_DELIBERATIVE_TOP_P=0.9
JARVIS_LLM_DELIBERATIVE_REPETITION_PENALTY=1.0

JARVIS_TTS_BACKEND=mlx_audio_kokoro
JARVIS_TTS_MODEL=mlx-community/Kokoro-82M-bf16
JARVIS_TTS_VOICE=pm_santa
JARVIS_TTS_LANG_CODE=p
JARVIS_TTS_AVSPEECH_VOICE=Luciana
JARVIS_TTS_AVSPEECH_RATE=175
JARVIS_TTS_SAMPLE_RATE_HZ=24000
JARVIS_PLAYBACK_BACKEND=sounddevice

JARVIS_ACTIVATION_BACKEND=push_to_talk
JARVIS_ACTIVATION_HOTKEY=<ctrl>+<alt>+space
JARVIS_ACTIVATION_TERMINAL_FALLBACK=true
JARVIS_ALLOWED_FILE_ROOTS=
JARVIS_SYSTEM_ALLOWED_APPS=Safari,Spotify,Notes,Calendar,Music,Mail,Terminal
JARVIS_WORKING_MEMORY_TURNS=12
JARVIS_TURN_SILENCE_TIMEOUT_MS=800
JARVIS_TURN_PARTIAL_COMMIT_MIN_CHARS=16
JARVIS_TURN_PARTIAL_STABILITY_MS=250
JARVIS_TURN_TICK_INTERVAL_MS=100
JARVIS_TURN_MAX_DURATION_S=30
JARVIS_LOG_LEVEL=INFO
JARVIS_LOG_FORMAT=auto
